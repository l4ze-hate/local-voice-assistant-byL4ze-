# --- Secrets / local config ---
key.env
.env
.env.*
*.env
*.local
!.env.example

# --- Python bytecode / cache ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Build / packaging ---
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# --- IDE / editor ---
.idea/
.vscode/
*.code-workspace
.qwen/

# --- OS files ---
.DS_Store
Thumbs.db

# --- Logs / runtime artifacts ---
*.log
.logs/
.data/
.cache/

# --- Documentation (track all except drafts) ---
!docs/*.md

# --- Scripts (track .bat/.sh, exclude temp files) ---
!scripts/*.bat
!scripts/*.sh

# --- Build artifacts (ignore generated) ---
build/
dist/
